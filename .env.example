# ----------------------------------------------------------------------
# Groot edition and deployment mode
# These settings choose which product edition is running.
# Start with these defaults for local development unless you are packaging
# Community Edition specifically.
# ----------------------------------------------------------------------

# Edition to run: internal, community, or cloud.
# In official builds this should match the build-embedded edition.
# Runtime config can narrow behavior, but it cannot elevate edition boundaries.
GROOT_EDITION=internal

# Tenancy mode must match the edition:
# - community -> single
# - internal/cloud -> multi
GROOT_TENANCY_MODE=multi

# Only used in Community Edition.
# If Groot starts with an empty database in community mode, it creates one
# bootstrap tenant with this name automatically.
COMMUNITY_TENANT_NAME=Community Tenant

# Optional signed license support.
# Point this at a publisher-issued JSON license file if your build expects one.
GROOT_LICENSE_PATH=

# Require a license file at startup.
# Leave false for local development unless you are testing licensed packaging.
GROOT_LICENSE_REQUIRED=false

# Optional override path for the Ed25519 public key used to verify licenses.
# Leave blank to use the key embedded into the official build.
GROOT_LICENSE_PUBLIC_KEY_PATH=

# Keep signature verification enabled for any real deployment.
GROOT_LICENSE_ENFORCE_SIGNATURE=true


# ----------------------------------------------------------------------
# Core service and infrastructure wiring
# These values tell Groot how to reach its own infrastructure.
# In local Docker setups, the defaults are usually correct.
# In managed environments, replace them with your real service endpoints.
# ----------------------------------------------------------------------

# HTTP listen address for the Groot API process.
GROOT_HTTP_ADDR=:8081

# PostgreSQL connection string.
# Use the value from your local Docker Compose stack or managed Postgres.
POSTGRES_DSN=postgres://groot:groot@postgres:5432/groot?sslmode=disable

# Comma-separated Kafka broker addresses.
# Use the broker hostnames from Docker Compose or your Kafka cluster.
KAFKA_BROKERS=kafka:19092

# Kafka consumer group for the in-process router.
# Usually safe to leave at the default unless you need a custom group name.
ROUTER_CONSUMER_GROUP=groot-router

# Temporal frontend address and namespace.
# Use the values from your Temporal deployment.
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default

# Shared system API key for system-only endpoints.
# Generate a long random secret for real deployments.
GROOT_SYSTEM_API_KEY=system-secret


# ----------------------------------------------------------------------
# Authentication and audit
# These settings control tenant auth, JWT verification, actor attribution,
# and audit event behavior. Leave JWT fields empty if you use only API keys.
# ----------------------------------------------------------------------

# Tenant auth mode: api_key, jwt, or mixed.
AUTH_MODE=api_key

# Header name for real tenant API keys created through /api-keys.
API_KEY_HEADER=X-API-Key

# Reserved tenant header name for embedding integrations.
TENANT_HEADER=X-Tenant-Id

# Optional actor metadata headers recorded into audit events.
ACTOR_ID_HEADER=X-Actor-Id
ACTOR_TYPE_HEADER=X-Actor-Type
ACTOR_EMAIL_HEADER=X-Actor-Email

# JWT identity provider settings.
# Get JWKS URL, issuer, and audience from your auth provider or IdP.
JWT_JWKS_URL=
JWT_AUDIENCE=
JWT_ISSUER=
JWT_REQUIRED_CLAIMS=sub,tenant_id
JWT_TENANT_CLAIM=tenant_id
JWT_CLOCK_SKEW_SECONDS=60

# Enable write-path audit events.
# Usually safe to leave enabled.
AUDIT_ENABLED=true

# Reserved flag for request-body logging in audits.
# Leave false unless you explicitly intend to capture request bodies.
AUDIT_LOG_REQUEST_BODY=false


# ----------------------------------------------------------------------
# Admin and operator controls
# These settings enable the /admin operator API surface.
# Leave admin mode disabled in simple self-hosted setups unless you need
# operator workflows.
# ----------------------------------------------------------------------

# Enable the /admin API surface.
ADMIN_MODE_ENABLED=false

# Admin auth mode: api_key or jwt.
ADMIN_AUTH_MODE=api_key

# Root operator API key used with X-Admin-Key.
# Generate a long random secret for real deployments.
ADMIN_API_KEY=

# Admin JWT settings, if you use JWT-based admin auth.
# Get these from your operator identity provider.
ADMIN_JWT_JWKS_URL=
ADMIN_JWT_ISSUER=
ADMIN_JWT_AUDIENCE=
ADMIN_JWT_REQUIRED_CLAIMS=sub

# Controls for admin data access and replay behavior.
ADMIN_ALLOW_VIEW_PAYLOADS=false
ADMIN_REPLAY_ENABLED=true
ADMIN_REPLAY_MAX_EVENTS=100
ADMIN_RATE_LIMIT_RPS=5


# ----------------------------------------------------------------------
# Event, replay, schema, graph, and platform controls
# These are platform behavior limits and safety knobs.
# Most deployments can keep these defaults unless tuning is required.
# ----------------------------------------------------------------------

# Allow tenant subscriptions to reference global connector instances.
GROOT_ALLOW_GLOBAL_INSTANCES=true

# Maximum internal event chain depth before Groot stops emitting more result events.
MAX_CHAIN_DEPTH=10

# Replay limits for tenant replay APIs.
MAX_REPLAY_EVENTS=1000
MAX_REPLAY_WINDOW_HOURS=24

# Event schema validation behavior: warn, reject, or off.
SCHEMA_VALIDATION_MODE=warn

# Event schema registration behavior: startup or migrate.
SCHEMA_REGISTRATION_MODE=startup

# Maximum payload size checked during schema validation.
SCHEMA_MAX_PAYLOAD_BYTES=262144

# Graph API limits.
GRAPH_MAX_NODES=5000
GRAPH_MAX_EDGES=20000
GRAPH_EXECUTION_TRAVERSAL_MAX_EVENTS=500
GRAPH_EXECUTION_MAX_DEPTH=25
GRAPH_DEFAULT_LIMIT=500


# ----------------------------------------------------------------------
# Provider-specific inbound and outbound integrations
# Replace these values when you enable the related provider.
# Leave unused providers at their defaults or blank values.
# ----------------------------------------------------------------------

# Stripe webhook signature tolerance in seconds.
# Usually safe to keep at the default.
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Resend integration settings.
# Get the API key from the Resend dashboard.
# The webhook public URL must be the externally reachable URL that Resend calls.
# The receiving domain is the inbound domain configured in Resend.
RESEND_API_KEY=re_test
RESEND_API_BASE_URL=https://api.resend.com
RESEND_WEBHOOK_PUBLIC_URL=https://example.com/webhooks/resend
RESEND_RECEIVING_DOMAIN=example.resend.app
RESEND_WEBHOOK_EVENTS=email.received

# Slack integration settings.
# SLACK_SIGNING_SECRET comes from your Slack app's Basic Information page.
# SLACK_API_BASE_URL is usually safe to leave at the default.
SLACK_API_BASE_URL=https://slack.com/api
SLACK_SIGNING_SECRET=slack-signing-secret

# Notion integration settings.
# NOTION_API_BASE_URL and NOTION_API_VERSION are usually safe to leave as-is
# unless you are testing against a mock or proxy.
NOTION_API_BASE_URL=https://api.notion.com/v1
NOTION_API_VERSION=2022-06-28


# ----------------------------------------------------------------------
# LLM provider configuration
# Populate these only for the providers you actually intend to use.
# API keys come from the respective provider consoles.
# ----------------------------------------------------------------------

# OpenAI provider configuration.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Anthropic provider configuration.
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# Groot defaults for LLM-backed connector operations.
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_CLASSIFY_MODEL=gpt-4o-mini
LLM_DEFAULT_EXTRACT_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30


# ----------------------------------------------------------------------
# Agent runtime and agent limits
# These settings control llm.agent behavior and the external runtime callback.
# Replace runtime URL and shared secret for real deployments.
# ----------------------------------------------------------------------

# Limits for agent execution inside Groot.
AGENT_MAX_STEPS=8
AGENT_STEP_TIMEOUT_SECONDS=30
AGENT_TOTAL_TIMEOUT_SECONDS=120
AGENT_MAX_TOOL_CALLS=8
AGENT_MAX_TOOL_OUTPUT_BYTES=16384

# External runtime backing llm.agent.
# AGENT_RUNTIME_BASE_URL should point at your agent runtime service.
# AGENT_RUNTIME_SHARED_SECRET must match the bearer secret the runtime sends
# to POST /internal/agent-runtime/tool-calls.
AGENT_RUNTIME_ENABLED=true
AGENT_RUNTIME_BASE_URL=http://localhost:8090
AGENT_RUNTIME_TIMEOUT_SECONDS=30
AGENT_SESSION_AUTO_CREATE=true
AGENT_SESSION_MAX_IDLE_DAYS=30
AGENT_MEMORY_MODE=runtime_managed
AGENT_MEMORY_SUMMARY_MAX_BYTES=16384
AGENT_RUNTIME_SHARED_SECRET=agent-runtime-secret


# ----------------------------------------------------------------------
# Delivery retry controls
# These settings govern Temporal retry behavior for outbound deliveries.
# Keep the defaults unless you need faster local retry loops or slower
# production retry pacing.
# ----------------------------------------------------------------------

DELIVERY_MAX_ATTEMPTS=10
DELIVERY_INITIAL_INTERVAL=2s
DELIVERY_MAX_INTERVAL=5m
